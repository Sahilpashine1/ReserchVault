# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# For local development:
MONGODB_URI=mongodb://localhost:27017/faculty_publications
# For production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/faculty_publications?retryWrites=true&w=majority

# JWT Secret (IMPORTANT: Change this in production!)
# Generate a strong random string for production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# File Upload
MAX_FILE_SIZE=5242880

# Role-Based Access Control Configuration
# IMPORTANT: Only the first Super Admin email is configured here
# All other admin accounts are created via the Admin Panel by Super Admin
# 
# Super Admin (Full system access - manages users, views logs, full CRUD)
SUPER_ADMIN_EMAIL=admin@college.edu

# Notes:
# - First user who registers with SUPER_ADMIN_EMAIL gets Super Admin role automatically
# - All other registrations get 'user' role by default
# - Super Admin can create/promote users to Admin Viewer or Super Admin via admin.html
# - This ensures maximum security and accountability
